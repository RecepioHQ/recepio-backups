# Recepio API Environment Variables
# ==========================================
# Copy this file to .env and fill in the values
# IMPORTANT: Never commit .env file to version control
# ==========================================

# ===========================================
# APPLICATION
# ===========================================
APP_NAME=Recepio API
APP_VERSION=2.0.0
DEBUG=false
API_PREFIX=/api/v1

# ===========================================
# DATABASE (PostgreSQL with pgvector)
# ===========================================
# Connection URLs (use async driver for FastAPI)
DATABASE_URL=postgresql+asyncpg://recepio:your_secure_password_here@postgres:5432/recepio
DATABASE_SYNC_URL=postgresql://recepio:your_secure_password_here@postgres:5432/recepio

# PostgreSQL Credentials
POSTGRES_USER=recepio
POSTGRES_PASSWORD=your_secure_password_here_CHANGE_ME
POSTGRES_DB=recepio

# Production URL override (when using external database)
#DATABASE_URL=postgresql+asyncpg://recepio:password@db.example.com:5432/recepio

# ===========================================
# REDIS
# ===========================================
REDIS_URL=redis://redis:6379/0

# Production URL override (when using external Redis)
#REDIS_URL=redis://redis.example.com:6379/0

# ===========================================
# JWT AUTHENTICATION
# ===========================================
# Generate a secure secret: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# ENCRYPTION
# ===========================================
# Master key for field encryption (must be exactly 32 bytes)
# Generate: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=your_32_byte_encryption_key_here

# ===========================================
# AI - CLAUDE (Anthropic)
# ===========================================
# Get your API key from: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-api03-your_claude_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=1024

# ===========================================
# STT - OPENAI WHISPER
# ===========================================
# Get your API key from: https://platform.openai.com/api-keys
STT_API_KEY=sk-proj-your_openai_api_key_here
STT_MODEL=whisper-1

# ===========================================
# TTS - EDGE-TTS (Free) + FALLBACK
# ===========================================
# Default voice for text-to-speech
TTS_DEFAULT_VOICE=ar-SA-HamedNeural

# Fallback TTS (Google Cloud TTS) - optional
#TTS_FALLBACK_API_KEY=your_google_cloud_tts_key_here

# ===========================================
# META / WHATSAPP BUSINESS API
# ===========================================
# Get credentials from: https://developers.facebook.com/apps/
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here

# WhatsApp webhook verification (choose any random string)
WHATSAPP_VERIFY_TOKEN=your_verify_token_here_random_string

# WhatsApp webhook secret (for signature verification)
WHATSAPP_WEBHOOK_SECRET=your_webhook_secret_here

# WhatsApp Business Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# ===========================================
# GOOGLE CALENDAR INTEGRATION
# ===========================================
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# OAuth callback URL (must match Google Cloud Console)
GOOGLE_CALENDAR_REDIRECT_URI=https://api.recepio.io/api/v1/calendar/callback

# ===========================================
# ZOHO MAIL INTEGRATION
# ==========================================
ZOHO_CLIENT_ID=your_zoho_client_id_here
ZOHO_CLIENT_SECRET=your_zoho_client_secret_here

# ===========================================
# PAYTABS PAYMENT GATEWAY
# ===========================================
# Get credentials from: https:// merchants.paytabs.com/
PAYTABS_PROFILE_ID=your_paytabs_profile_id_here
PAYTABS_SERVER_KEY=your_paytabs_server_key_here
PAYTABS_BASE_URL=https://secure.paytabs.com

# For testing use: https://secure.paytabs.com
# For production use same URL (PayTabs handles environment in dashboard)

# ===========================================
# BACKUP - BACKBLAZE B2
# ===========================================
# Get credentials from: https://secure.backblaze.com/appkeys
B2_KEY_ID=your_b2_key_id_here
B2_APPLICATION_KEY=your_b2_application_key_here
BACKUP_ENCRYPTION_KEY=your_backup_encryption_key_here

# ===========================================
# CORS (Cross-Origin Resource Sharing)
# ===========================================
# Comma-separated list of allowed origins
# For development:
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000,http://app.localhost

# For production:
#CORS_ORIGINS=https://app.recepio.io,https://admin.recepio.io

# ===========================================
# LOGGING
# ===========================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===========================================
# DOCKER / INFRASTRUCTURE
# ===========================================
# Required for Caddy DNS challenge with Cloudflare
#CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# ===========================================
# MONITORING (Optional)
# ===========================================
# Sentry error tracking (optional)
#SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# Prometheus metrics (optional)
#PROMETHEUS_ENABLED=true
#PROMETHEUS_PORT=9090
